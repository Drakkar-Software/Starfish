{
  "name": "@starfish/server",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Drakkar-Software/starfish.git",
    "directory": "packages/ts/server"
  },
  "description": "TypeScript server for the Starfish sync protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@starfish/protocol": "workspace:*",
    "hono": "^4.12.7"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "files": ["dist"]
}
