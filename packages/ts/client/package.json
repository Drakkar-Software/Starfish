{
  "name": "@starfish/client",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Drakkar-Software/starfish.git",
    "directory": "packages/ts/client"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "description": "TypeScript client SDK for the Starfish sync protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./zustand": {
      "types": "./dist/bindings/zustand.d.ts",
      "import": "./dist/bindings/zustand.js"
    },
    "./legend": {
      "types": "./dist/bindings/legend.d.ts",
      "import": "./dist/bindings/legend.js"
    }
  },
  "peerDependencies": {
    "zustand": ">=4.0.0",
    "immer": ">=9.0.0",
    "@legendapp/state": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "zustand": {
      "optional": true
    },
    "immer": {
      "optional": true
    },
    "@legendapp/state": {
      "optional": true
    }
  },
  "dependencies": {
    "@starfish/protocol": "workspace:*"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@legendapp/state": "^2.0.0",
    "hono": "^4.12.7",
    "immer": "^11.1.4",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "zustand": "^5.0.11"
  },
  "files": [
    "dist"
  ]
}
